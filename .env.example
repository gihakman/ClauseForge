# Copy to .env and fill in.
# .env is gitignored; NEVER commit real values.

# Funded GenLayer Bradbury testnet private key (used to sign deploy + seed transactions).
# 0x-prefixed 64-hex-char string.
ACCOUNT_PRIVATE_KEY=

# Optional protocol config for the ClauseForge contract.
# FEE_RECIPIENT: address that receives per-compilation fees. Blank = deployer.
FEE_RECIPIENT=

# FEE_BPS: fee in basis points (1/100th of a percent). Default 100 (=1%).
# Currently used only as a display value in the frontend; the contract charges a flat GEN fee.
FEE_BPS=100
